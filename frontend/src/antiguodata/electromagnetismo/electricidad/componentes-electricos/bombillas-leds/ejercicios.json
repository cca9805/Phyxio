    "title": "Consumo Anual",
    "enunciado": "Una bombilla LED de 10W está encendida 5 horas al día. ¿Cuántos kWh consume al año?",
    "solution": {
      "steps": [
        "Horas al año = 5h/día × 365 días = 1825 horas",
        "Consumo = (10W × 1825h) / 1000",
        "Consumo = 18.25 kWh al año"
      ],
      "result": "Consume 18.25 kWh al año"
    }
