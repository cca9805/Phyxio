        "id": "ejercicio-masa-resorte-1",
        "groupId": "sistema-masa-resorte",
        "title": "Ejercicio: Calcular Periodo de un Resorte",
        "enunciado": "Un sistema masa-resorte tiene una masa de 0.5 kg y una constante de resorte de 50 N/m. ¿Cuál es su periodo de oscilación (T)?",
        "solution": {
            "steps": [
                "Datos: m = 0.5 kg, k = 50 N/m",
                "Fórmula: T = 2π * sqrt(m/k)", 
                "Sustitución: T = 2π * sqrt(0.5 / 50)", 
                "Resultado: T ≈ 0.628 s"
            ],
            "result": "Aproximadamente 0.628 s"
        }
    },
    {
        "id": "ejercicio-masa-resorte-2",
        "groupId": "sistema-masa-resorte",
        "title": "Ejercicio: Calcular Masa en un Resorte",
        "enunciado": "Un resorte con k = 100 N/m oscila con un periodo de 1.5 segundos. ¿Qué masa (m) tiene acoplada?",
        "solution": {
            "steps": [
                "Datos: k = 100 N/m, T = 1.5 s",
                "Fórmula: m = k * (T / 2π)²", 
                "Sustitución: m = 100 * (1.5 / (2π))²", 
                "Resultado: m ≈ 5.7 kg"
            ],
            "result": "Aproximadamente 5.7 kg"
        }
    },
