        "id": "ejercicio-energia-mas-2",
        "groupId": "energia-mas",
        "title": "Ejercicio: Calcular Constante desde Energía",
        "enunciado": "Un sistema oscilante tiene una energía total de 5 J y una amplitud de 0.25 m. ¿Cuál es la constante del resorte (k)?",
        "solution": {
            "steps": [
                "Datos: E_T = 5 J, A = 0.25 m",
                "Fórmula: k = 2 * E_T / A²", 
                "Sustitución: k = (2 * 5) / 0.25²", 
                "Resultado: k = 160 N/m"
            ],
            "result": "160 N/m"
        }
