        "enunciado": "Un motor gira con una frecuencia de 60 Hz. ¿Cuál es su frecuencia angular (ω)?",
        "solution": {
            "steps": [
                "Datos: f = 60 Hz",
                "Fórmula: ω = 2πf", 
                "Sustitución: ω = 2π * 60", 
                "Resultado: ω ≈ 377 rad/s"
            ],
            "result": "Aproximadamente 377 rad/s"
        }
