        "groupId": "energia-mas",
        "title": "Ejercicio: Calcular Energía Total en MAS",
        "enunciado": "Un resorte de k = 200 N/m oscila con una amplitud de 0.1 metros. ¿Cuál es la energía mecánica total (E_T) del sistema?",
        "solution": {
            "steps": [
                "Datos: k = 200 N/m, A = 0.1 m",
                "Fórmula: E_T = 0.5 * k * A²", 
                "Sustitución: E_T = 0.5 * 200 * (0.1)²", 
                "Resultado: E_T = 1 J"
            ],
            "result": "1 J"
        }
