  {
    "id": "flotabilidad-ejercicio-03",
    "groupId": "peso-aparente",
    "title": "Peso Aparente de una Roca",
    "enunciado": "Una roca de 50 kg (ρ = 2500 kg/m³) se sumerge en agua. Calcula su peso aparente.",
    "solution": {
      "steps": [
        "Peso real: W = m × g = 50 × 9.81 = 490.5 N",
        "Volumen: V = m / ρ = 50 / 2500 = 0.02 m³",
        "Empuje: E = 1000 × 9.81 × 0.02 = 196.2 N",
        "Peso aparente: W_ap = W - E = 490.5 - 196.2",
        "Resultado: W_ap = 294.3 N (reducción del 40%)"
      ],
      "result": "294.3 N"
    }
  },
  {
    "id": "flotabilidad-ejercicio-04",
    "groupId": "carga-maxima",
    "title": "Capacidad de Carga de un Barco",
    "enunciado": "Un barco de 5000 kg tiene un volumen total de 8 m³. ¿Cuánta carga puede transportar sin hundirse?",
    "solution": {
      "steps": [
        "Masa máxima total: m_max = ρ_agua × V = 1000 × 8 = 8000 kg",
        "Carga máxima: m_carga = m_max - m_barco",
        "m_carga = 8000 - 5000 = 3000 kg",
        "Resultado: 3000 kg = 3 toneladas"
      ],
      "result": "3 toneladas"
    }
  },
