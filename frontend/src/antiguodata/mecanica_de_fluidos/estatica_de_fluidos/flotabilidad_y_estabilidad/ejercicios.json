    "id": "flotabilidad-ejercicio-10",
    "groupId": "estabilidad-metacentrica",
    "title": "Estabilidad de un Pontón",
    "enunciado": "Un pontón rectangular tiene I = 2 m⁴, V_sumergido = 10 m³, y BG = 0.15 m. Determina si es estable.",
    "solution": {
      "steps": [
        "BM = I / V_sumergido = 2 / 10 = 0.2 m",
        "GM = BM - BG = 0.2 - 0.15 = 0.05 m",
        "GM > 0, por lo tanto el pontón es ESTABLE",
        "Resultado: GM = 0.05 m (ESTABLE)"
      ],
      "result": "ESTABLE (GM = 0.05 m)"
    }
  },
