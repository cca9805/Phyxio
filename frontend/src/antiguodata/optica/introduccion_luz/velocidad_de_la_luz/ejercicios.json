    "title": "Distancia Sol→Tierra desde tiempo",
    "enunciado": "Si la luz tarda 8 minutos en llegar del Sol a la Tierra, ¿qué distancia recorre?",
    "solution": {
      "steps": [
        "Datos: t = 8 min = 480 s; c = 299.792.458 m/s",
        "Fórmula: d = c · t",
        "Sustitución: d = 299.792.458 · 480",
        "Resultado: d ≈ 1.439×10^11 m (≈144 millones km)"
      ],
      "result": "Aproximadamente 1.44×10^11 m (144 millones de km)"
    }
