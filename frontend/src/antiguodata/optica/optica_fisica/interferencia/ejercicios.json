    "enunciado": "En Young, calcula la separación entre franjas consecutivas si d = 0.4 mm, L = 2 m y λ = 600 nm.",
    "solution": {
      "steps": [
        "Datos: d = 4 × 10⁻⁴ m, L = 2 m, λ = 6 × 10⁻⁷ m",
        "Separación: Δy = λL/d",
        "Δy = (6 × 10⁻⁷ × 2)/(4 × 10⁻⁴)",
        "Δy = (1.2 × 10⁻⁶)/(4 × 10⁻⁴)",
        "Δy = 0.003 m = 3 mm"
      ],
      "result": "3 mm"
    }
  },
