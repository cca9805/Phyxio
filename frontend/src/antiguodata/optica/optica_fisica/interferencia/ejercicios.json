  {
    "id": "interferencia-young-01",
    "groupId": "doble-rendija-young",
    "title": "Doble Rendija de Young",
    "enunciado": "En el experimento de Young, d = 0.5 mm, L = 2 m y λ = 600 nm. Calcula la posición del segundo máximo (m=2).",
    "solution": {
      "steps": [
        "Datos: m = 2, λ = 6 × 10⁻⁷ m, L = 2 m, d = 5 × 10⁻⁴ m",
        "Fórmula: y = (mλL)/d",
        "y = (2 × 6 × 10⁻⁷ × 2)/(5 × 10⁻⁴)",
        "y = (2.4 × 10⁻⁶)/(5 × 10⁻⁴)",
        "y = 0.0048 m = 4.8 mm"
      ],
      "result": "4.8 mm"
    }
  },
  {
    "id": "interferencia-young-02",
    "groupId": "doble-rendija-young",
    "title": "Primer Máximo en Young",
    "enunciado": "Con d = 0.3 mm, L = 1.5 m y λ = 500 nm, calcula la posición del primer máximo (m=1).",
    "solution": {
      "steps": [
        "Datos: m = 1, λ = 5 × 10⁻⁷ m, L = 1.5 m, d = 3 × 10⁻⁴ m",
        "Fórmula: y = (mλL)/d",
        "y = (1 × 5 × 10⁻⁷ × 1.5)/(3 × 10⁻⁴)",
        "y = (7.5 × 10⁻⁷)/(3 × 10⁻⁴)",
        "y = 0.0025 m = 2.5 mm"
      ],
      "result": "2.5 mm"
    }
