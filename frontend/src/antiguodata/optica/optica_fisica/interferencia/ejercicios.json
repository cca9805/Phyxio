    "solution": {
      "steps": [
        "Datos: m = 1, λ = 480 nm = 4.8 × 10⁻⁷ m",
        "Fórmula: Δx = (m + 1/2)λ",
        "Δx = (1 + 0.5) × 4.8 × 10⁻⁷",
        "Δx = 1.5 × 4.8 × 10⁻⁷ = 7.2 × 10⁻⁷ m = 720 nm"
      ],
      "result": "720 nm"
    }
