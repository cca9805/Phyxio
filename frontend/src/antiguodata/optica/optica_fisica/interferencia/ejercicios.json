    "title": "Interferencia Destructiva",
    "enunciado": "Calcula la diferencia de camino para el primer mínimo (m=0) con luz de 550 nm.",
    "solution": {
      "steps": [
        "Datos: m = 0, λ = 550 nm = 5.5 × 10⁻⁷ m",
        "Fórmula: Δx = (m + 1/2)λ",
        "Δx = (0 + 0.5) × 5.5 × 10⁻⁷",
        "Δx = 2.75 × 10⁻⁷ m = 275 nm"
      ],
      "result": "275 nm"
    }
  },
  {
    "id": "interferencia-destructiva-02",
