  {
    "id": "interferencia-pelicula-01",
    "groupId": "pelicula-delgada",
    "title": "Película Delgada",
    "enunciado": "Una película de aceite (n=1.5) tiene un espesor de 300 nm. Para m=1, ¿qué longitud de onda produce interferencia constructiva?",
    "solution": {
      "steps": [
        "Datos: n = 1.5, t = 300 nm = 3 × 10⁻⁷ m, m = 1",
        "Fórmula: 2nt = mλ → λ = 2nt/m",
        "λ = (2 × 1.5 × 3 × 10⁻⁷)/1",
        "λ = 9 × 10⁻⁷ m = 900 nm"
      ],
      "result": "900 nm"
    }
  },
  {
    "id": "interferencia-pelicula-02",
    "groupId": "pelicula-delgada",
    "title": "Espesor de Película",
    "enunciado": "Una película con n=1.4 produce interferencia constructiva de primer orden para λ=560 nm. Calcula el espesor.",
    "solution": {
      "steps": [
        "Datos: n = 1.4, λ = 560 nm = 5.6 × 10⁻⁷ m, m = 1",
        "Fórmula: 2nt = mλ → t = mλ/(2n)",
        "t = (1 × 5.6 × 10⁻⁷)/(2 × 1.4)",
        "t = (5.6 × 10⁻⁷)/2.8 = 2 × 10⁻⁷ m = 200 nm"
      ],
      "result": "200 nm"
    }
  },
