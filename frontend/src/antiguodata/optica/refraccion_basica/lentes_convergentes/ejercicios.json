    "solution": {
      "steps": [
        "\\frac{1}{d_i} = \\frac{1}{10} - \\frac{1}{15} = 0.1 - 0.0667 = 0.0333",
        "d_i = \\frac{1}{0.0333} ≈ 30 \\; cm",
        "m = - \\frac{d_i}{d_o} = - \\frac{30}{15} = -2",
