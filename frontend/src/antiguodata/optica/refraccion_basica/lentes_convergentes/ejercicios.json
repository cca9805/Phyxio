    "id": "lc-1",
    "groupId": "lentes-convergentes",
    "title": "Objeto lejos (más allá de 2f)",
    "enunciado": "Una lente convergente tiene f = 10 cm. Un objeto se coloca a d_o = 30 cm. Calcula d_i y m, y clasifica la imagen.",
    "solution": {
      "steps": [
        "\\frac{1}{d_i} = \\frac{1}{f} - \\frac{1}{d_o} = \\frac{1}{10} - \\frac{1}{30} = 0.1 - 0.0333 = 0.0667",
        "d_i = \\frac{1}{0.0667} ≈ 15 \\; cm",
        "m = - \\frac{d_i}{d_o} = - \\frac{15}{30} = -0.5",
        "Imagen real, invertida, reducida"
      ],
      "result": "d_i ≈ 15 cm, m = -0.5 (real, invertida, reducida)"
    }
  },
  {
