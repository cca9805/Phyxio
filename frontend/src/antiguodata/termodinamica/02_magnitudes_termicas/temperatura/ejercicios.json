  {
    "id": "temperatura-ejercicio-08",
    "groupId": "temperatura-energia-cinetica",
    "title": "Energía Cinética a Temperatura Ambiente",
    "enunciado": "Calcula la energía cinética promedio de una molécula de gas a 300 K.",
    "solution": {
      "steps": [
        "Datos: T = 300 K, k_B = 1.381 × 10⁻²³ J/K",
        "Fórmula: E_c = (3/2) × k_B × T",
        "Sustitución: E_c = (3/2) × 1.381×10⁻²³ × 300",
        "Cálculo: E_c = 2.0715 × 10⁻²³ × 300",
        "Resultado: E_c = 6.21 × 10⁻²¹ J"
      ],
      "result": "6.21 × 10⁻²¹ J"
    }
  },
  {
    "id": "temperatura-ejercicio-09",
