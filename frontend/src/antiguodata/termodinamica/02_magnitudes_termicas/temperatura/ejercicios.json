    "id": "temperatura-ejercicio-04",
    "groupId": "temperatura-celsius-fahrenheit",
    "title": "Temperatura Corporal",
    "enunciado": "La temperatura corporal normal es de 37°C. ¿Cuál es esta temperatura en Fahrenheit?",
    "solution": {
      "steps": [
        "Datos: T(°C) = 37°C",
        "Fórmula: T(°F) = (9/5) × T(°C) + 32",
        "Sustitución: T(°F) = (9/5) × 37 + 32",
        "Cálculo: T(°F) = 66.6 + 32",
        "Resultado: T(°F) = 98.6°F"
      ],
      "result": "98.6°F"
    }
  },
