    "title": "Temperatura Ambiente a Kelvin",
    "enunciado": "La temperatura ambiente en una habitación es de 22°C. Expresa esta temperatura en Kelvin.",
    "solution": {
      "steps": [
        "Datos: T(°C) = 22°C",
        "Fórmula: T(K) = T(°C) + 273.15",
        "Sustitución: T(K) = 22 + 273.15",
        "Resultado: T(K) = 295.15 K"
      ],
      "result": "295.15 K"
    }
