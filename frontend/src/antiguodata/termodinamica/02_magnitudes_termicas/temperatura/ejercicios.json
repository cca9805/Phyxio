    "title": "Energía a Alta Temperatura",
    "enunciado": "A 400 K, calcula la energía cinética promedio de las moléculas de oxígeno (O₂) en el aire.",
    "solution": {
      "steps": [
        "Datos: T = 400 K, k_B = 1.381 × 10⁻²³ J/K",
        "Fórmula: E_c = (3/2) × k_B × T",
        "Sustitución: E_c = (3/2) × 1.381×10⁻²³ × 400",
        "Cálculo: E_c = 2.0715 × 10⁻²³ × 400",
        "Resultado: E_c = 8.29 × 10⁻²¹ J"
      ],
      "result": "8.29 × 10⁻²¹ J"
    }
  },
  {
    "id": "temperatura-ejercicio-10",
    "groupId": "temperatura-energia-cinetica",
    "title": "Temperatura desde Energía",
    "enunciado": "Si la energía cinética promedio de las moléculas de un gas es 4.14 × 10⁻²¹ J, ¿cuál es la temperatura del gas?",
    "solution": {
      "steps": [
        "Datos: E_c = 4.14 × 10⁻²¹ J, k_B = 1.381 × 10⁻²³ J/K",
        "Fórmula: T = (2/3) × (E_c / k_B)",
        "Sustitución: T = (2/3) × (4.14×10⁻²¹ / 1.381×10⁻²³)",
        "Cálculo: T = (2/3) × 299.78",
        "Resultado: T = 200 K"
      ],
      "result": "200 K"
    }
  }
]
