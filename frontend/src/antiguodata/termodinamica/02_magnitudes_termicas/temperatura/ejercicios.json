    "enunciado": "El agua se congela a 32°F. ¿Cuál es esta temperatura en Celsius?",
    "solution": {
      "steps": [
        "Datos: T(°F) = 32°F",
        "Fórmula: T(°C) = (5/9) × [T(°F) - 32]",
        "Sustitución: T(°C) = (5/9) × [32 - 32]",
        "Cálculo: T(°C) = (5/9) × 0",
        "Resultado: T(°C) = 0°C"
      ],
      "result": "0°C"
    }
