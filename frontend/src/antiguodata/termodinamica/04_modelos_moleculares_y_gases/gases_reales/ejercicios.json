    "id": "gas-real-ejercicio-01",
    "groupId": "gases_reales-grupo-1",
    "title": "Presión según Van der Waals",
    "enunciado": "Calcula la presión de 2 moles de CO₂ en 1 m³ a 300 K usando Van der Waals. Para CO₂: a = 0.3658 Pa·m⁶/mol², b = 4.267×10⁻⁵ m³/mol",
    "solution": {
      "steps": [
        "Datos: n = 2 mol, T = 300 K, V = 1 m³, a = 0.3658, b = 4.267×10⁻⁵",
        "Fórmula: P = [nRT/(V-nb)] - [an²/V²]",
        "Término 1: (2 × 8.314 × 300) / (1 - 2 × 4.267×10⁻⁵) = 4988.4 / 0.999915 = 4988.8 Pa",
        "Término 2: (0.3658 × 4) / 1 = 1.463 Pa",
        "Resultado: P = 4988.8 - 1.463 = 4987.3 Pa"
      ],
      "result": "4987.3 Pa"
    }
  },
  {
    "id": "gas-real-ejercicio-02",
    "groupId": "gases_reales-grupo-1",
    "title": "Factor de Compresibilidad",
    "enunciado": "Un gas real a 200000 Pa ocupa 0.5 m³ con 3 moles a 400 K. Calcula el factor Z.",
    "solution": {
      "steps": [
        "Datos: P = 200000 Pa, V = 0.5 m³, n = 3 mol, T = 400 K",
        "Fórmula: Z = (PV) / (nRT)",
        "Sustitución: Z = (200000 × 0.5) / (3 × 8.314 × 400)",
        "Cálculo: Z = 100000 / 9976.8",
        "Resultado: Z = 10.02",
        "Interpretación: Z > 1, fuerzas repulsivas dominan"
      ],
      "result": "Z = 10.02"
    }
  },
  {
    "id": "gas-real-ejercicio-03",
    "groupId": "gases_reales-grupo-1",
    "title": "Comparación Gas Ideal vs Real",
    "enunciado": "Compara la presión de 1 mol de N₂ en 0.1 m³ a 273 K usando gas ideal y Van der Waals (a = 0.1408, b = 3.913×10⁻⁵).",
    "solution": {
      "steps": [
        "Gas ideal: P = nRT/V = (1 × 8.314 × 273) / 0.1 = 22697.2 Pa",
        "Van der Waals término 1: (1 × 8.314 × 273) / (0.1 - 3.913×10⁻⁵) = 22706.1 Pa",
        "Van der Waals término 2: (0.1408 × 1) / 0.01 = 14.08 Pa",
        "Van der Waals: P = 22706.1 - 14.08 = 22692.0 Pa",
        "Diferencia: 22697.2 - 22692.0 = 5.2 Pa (0.02%)"
      ],
      "result": "Ideal: 22697 Pa, Real: 22692 Pa"
    }
  }
]
