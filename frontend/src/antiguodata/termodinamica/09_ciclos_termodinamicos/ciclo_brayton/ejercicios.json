[
  {
    "id": "brayton-ejercicio-01",
    "groupId": "ciclo_brayton-grupo-1",
    "title": "Eficiencia del Ciclo Brayton",
    "enunciado": "Una turbina de gas tiene relación de presiones de 10. Calcula su eficiencia. (γ=1.4)",
    "solution": {
      "steps": [
        "Datos: r_p = 10, γ = 1.4",
        "η_Brayton = 1 - 1/r_p^[(γ-1)/γ]",
        "Exponente: (1.4-1)/1.4 = 0.286",
        "η_Brayton = 1 - 1/10^0.286 = 1 - 1/1.965",
        "η_Brayton = 1 - 0.509 = 0.491 = 49.1%"
      ],
      "result": "49.1%"
    }
  }
]
