[
  {
    "id": "diesel-ejercicio-01",
    "groupId": "ciclo_diesel-grupo-1",
    "title": "Eficiencia del Ciclo Diesel",
    "enunciado": "Un motor Diesel tiene r=18 y r_c=2. Calcula su eficiencia. (γ=1.4)",
    "solution": {
      "steps": [
        "Datos: r = 18, r_c = 2, γ = 1.4",
        "η_Diesel = 1 - [1/r^(γ-1)] × [(r_c^γ - 1)/(γ(r_c - 1))]",
        "Término 1: 1/18^0.4 = 0.318",
        "Término 2: (2^1.4 - 1)/(1.4×1) = 1.639/1.4 = 1.171",
        "η_Diesel = 1 - 0.318 × 1.171 = 1 - 0.372 = 0.628 = 62.8%"
      ],
      "result": "62.8%"
    }
  }
]
