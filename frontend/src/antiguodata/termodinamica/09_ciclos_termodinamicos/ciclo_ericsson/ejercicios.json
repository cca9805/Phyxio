[
  {
    "id": "ericsson-ejercicio-01",
    "groupId": "ciclo_ericsson-grupo-1",
    "title": "Eficiencia del Ciclo Ericsson",
    "enunciado": "Un ciclo Ericsson opera entre 300 K y 900 K. Calcula su eficiencia teórica.",
    "solution": {
      "steps": [
        "Datos: T_C = 300 K, T_H = 900 K",
        "η_Ericsson = 1 - T_C / T_H",
        "η_Ericsson = 1 - 300 / 900",
        "η_Ericsson = 1 - 0.333 = 0.667 = 66.7%"
      ],
      "result": "66.7%"
    }
  }
]
