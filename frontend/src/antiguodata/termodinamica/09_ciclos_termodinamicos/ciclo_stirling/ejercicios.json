    "id": "stirling-ejercicio-01",
    "groupId": "ciclo_stirling-grupo-1",
    "title": "Eficiencia del Ciclo Stirling",
    "enunciado": "Un motor Stirling opera entre 400 K y 800 K. Calcula su eficiencia teórica.",
    "solution": {
      "steps": [
        "Datos: T_C = 400 K, T_H = 800 K",
        "η_Stirling = 1 - T_C / T_H",
        "η_Stirling = 1 - 400 / 800",
        "η_Stirling = 1 - 0.5 = 0.5 = 50%"
      ],
      "result": "50%"
    }
  }
]
