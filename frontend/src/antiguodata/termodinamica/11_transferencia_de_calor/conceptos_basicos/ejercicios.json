    "title": "Flujo de Calor Básico",
    "enunciado": "Con ΔT=50 K y R_th=0.1 K/W, calcula el flujo de calor.",
    "solution": {
      "steps": [
        "Datos: ΔT = 50 K, R_th = 0.1 K/W",
        "Fórmula: Q = ΔT / R_th",
        "Q = 50 / 0.1",
        "Q = 500 W"
      ],
      "result": "500 W"
    }
  }
