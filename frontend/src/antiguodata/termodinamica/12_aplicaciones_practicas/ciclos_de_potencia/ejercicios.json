    "title": "Trabajo Neto",
    "enunciado": "Una turbina produce 500 kJ y el compresor consume 150 kJ. Calcula el trabajo neto.",
    "solution": {
      "steps": [
        "Datos: W_turbina = 500 kJ, W_compresor = 150 kJ",
        "Fórmula: W_neto = W_turbina - W_compresor",
        "W_neto = 500 - 150",
        "W_neto = 350 kJ"
      ],
      "result": "350 kJ"
    }
  },
