    "title": "Eficiencia Térmica",
    "enunciado": "Con W_neto=350 kJ y Q_entrada=1000 kJ, calcula la eficiencia.",
    "solution": {
      "steps": [
        "Datos: W_neto = 350 kJ, Q_entrada = 1000 kJ",
        "Fórmula: η_th = W_neto / Q_entrada",
        "η_th = 350 / 1000",
        "η_th = 0.35 = 35%"
      ],
      "result": "35%"
    }
  }
