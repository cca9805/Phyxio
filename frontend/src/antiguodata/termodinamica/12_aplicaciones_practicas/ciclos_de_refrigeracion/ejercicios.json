    "id": "refrig-ejercicio-01",
    "groupId": "ciclos_de_refrigeracion-grupo-1",
    "title": "COP de Refrigerador",
    "enunciado": "Un refrigerador extrae 2000 J de calor consumiendo 800 J de trabajo. Calcula el COP.",
    "solution": {
      "steps": [
        "Datos: Q_L = 2000 J, W = 800 J",
        "Fórmula: COP_R = Q_L / W",
        "COP_R = 2000 / 800",
        "COP_R = 2.5"
      ],
      "result": "COP_R = 2.5"
    }
  },
  {
    "id": "refrig-ejercicio-02",
    "groupId": "ciclos_de_refrigeracion-grupo-1",
    "title": "Consumo de Refrigerador",
    "enunciado": "Refrigerador debe extraer 500 W con COP_R=2.0. Calcula potencia eléctrica y consumo anual (8 h/día).",
    "solution": {
      "steps": [
        "Datos: Q_L = 500 W, COP_R = 2.0",
        "Fórmula: W = Q_L / COP_R",
        "W = 500 / 2.0 = 250 W",
        "Consumo diario: 0.25 kW × 8 h = 2 kWh/día",
        "Consumo anual: 2 × 365 = 730 kWh/año"
      ],
      "result": "250 W, 730 kWh/año"
    }
  },
  {
    "id": "refrig-ejercicio-03",
    "groupId": "ciclos_de_refrigeracion-grupo-1",
    "title": "Comparación de Eficiencia",
    "enunciado": "Refrigerador A (COP=1.8, 400€) vs B (COP=2.5, 600€). Ambos extraen 400 W, 10 h/día. ¿Cuál es mejor a 5 años? (0.15 €/kWh)",
    "solution": {
      "steps": [
        "Refrigerador A:",
        "Potencia: 400/1.8 = 222 W",
        "Consumo anual: 0.222 × 10 × 365 = 811 kWh/año",
        "Costo 5 años: 811 × 5 × 0.15 = 608 €",
        "Total: 400 + 608 = 1008 €",
        "Refrigerador B:",
        "Potencia: 400/2.5 = 160 W",
        "Consumo anual: 0.160 × 10 × 365 = 584 kWh/año",
        "Costo 5 años: 584 × 5 × 0.15 = 438 €",
        "Total: 600 + 438 = 1038 €",
        "Refrigerador A es ligeramente mejor a 5 años, pero B es más eficiente a largo plazo"
      ],
      "result": "A: 1008€, B: 1038€ (5 años)"
    }
  }
]
