    "id": "clima-ejercicio-01",
    "groupId": "sistemas_de_climatizacion-grupo-1",
    "title": "Carga Térmica Total",
    "enunciado": "Un local tiene carga sensible de 8000 W y latente de 2000 W. Calcula la carga total.",
    "solution": {
      "steps": [
        "Datos: Q_sensible = 8000 W, Q_latente = 2000 W",
        "Fórmula: Q_total = Q_sensible + Q_latente",
        "Q_total = 8000 + 2000",
        "Q_total = 10000 W = 10 kW",
        "En TR: 10000 / 3516.85 = 2.84 TR"
      ],
      "result": "10 kW (2.84 TR)"
    }
  },
  {
    "id": "clima-ejercicio-02",
    "groupId": "sistemas_de_climatizacion-grupo-1",
    "title": "EER de Aire Acondicionado",
    "enunciado": "Un AC de 12000 BTU/h consume 1000 W. Calcula el EER.",
    "solution": {
      "steps": [
        "Datos: Q_enfriamiento = 12000 BTU/h, W_electrico = 1000 W",
        "Fórmula: EER = Q_enfriamiento / W_electrico",
        "EER = 12000 / 1000",
        "EER = 12 BTU/(W·h)"
      ],
      "result": "EER = 12 BTU/(W·h)"
    }
  },
  {
    "id": "clima-ejercicio-03",
    "groupId": "sistemas_de_climatizacion-grupo-1",
    "title": "Dimensionamiento de AC",
    "enunciado": "Oficina de 50 m², 10 personas, 5 ordenadores (200W c/u), iluminación 15 W/m². Estima carga sensible.",
    "solution": {
      "steps": [
        "Transmisión muros/ventanas: 50 × 60 = 3000 W (estimado)",
        "Ocupantes: 10 × 70 = 700 W",
        "Ordenadores: 5 × 200 = 1000 W",
        "Iluminación: 50 × 15 = 750 W",
        "Q_sensible = 3000 + 700 + 1000 + 750 = 5450 W",
        "Con factor de seguridad 20%: 5450 × 1.2 = 6540 W",
        "Capacidad requerida ≈ 6.5 kW"
      ],
      "result": "≈ 6.5 kW de capacidad"
    }
  },
  {
    "id": "clima-ejercicio-04",
    "groupId": "sistemas_de_climatizacion-grupo-1",
    "title": "Ahorro con Alta Eficiencia",
    "enunciado": "AC de 3 kW, 8 h/día, 120 días/año. Compara consumo entre EER=2.5 y EER=3.5 (0.15 €/kWh).",
    "solution": {
      "steps": [
        "Horas totales: 8 × 120 = 960 h/año",
        "EER 2.5: Potencia = 3/2.5 = 1.2 kW",
        "Consumo: 1.2 × 960 = 1152 kWh/año",
        "Costo: 1152 × 0.15 = 172.8 €/año",
        "EER 3.5: Potencia = 3/3.5 = 0.857 kW",
        "Consumo: 0.857 × 960 = 823 kWh/año",
        "Costo: 823 × 0.15 = 123.4 €/año",
        "Ahorro: 172.8 - 123.4 = 49.4 €/año (29%)"
      ],
      "result": "Ahorro: 49.4 €/año (29%)"
    }
  }
]
