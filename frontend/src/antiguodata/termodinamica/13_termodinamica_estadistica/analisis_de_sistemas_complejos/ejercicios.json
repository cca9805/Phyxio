    "enunciado": "Calcula P_∞ para p = 0.6, p_c = 0.5927, β_perc = 0.139.",
    "solution": {
      "steps": [
        "Datos: p = 0.6, p_c = 0.5927, β_perc = 0.139",
        "P_∞ = (p - p_c)^β_perc",
        "P_∞ = (0.6 - 0.5927)^0.139",
        "P_∞ = 0.0073^0.139 = 0.52",
        "Resultado: 52% de probabilidad de cluster infinito"
