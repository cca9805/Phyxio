    "title": "Calor Específico Crítico",
    "enunciado": "Calcula el calor específico C cerca de la temperatura crítica si T = 650 K, T_c = 647.1 K, α = 0.11 y A = 100 J/K. Explica cada paso.",
    "solution": {
      "steps": [
        "Datos: T = 650 K, T_c = 647.1 K, α = 0.11, A = 100 J/K",
        "t = |T - T_c|/T_c = |650 - 647.1|/647.1 = 2.9/647.1 = 0.00448",
        "C = A × t^(-α) = 100 × 0.00448^(-0.11)",
        "Resultado: C = 127 J/K"
      ],
      "result": "127 J/K"
    }
  },
