[
  {
    "id": "cuantica-ejercicio-01",
    "groupId": "planck-ley",
    "title": "Radiación a 5000 Hz",
    "enunciado": "Calcula la densidad espectral de energía para ν = 5 × 10¹⁴ Hz a T = 5778 K (Sol).",
    "solution": {
      "steps": [
        "Datos: ν = 5 × 10¹⁴ Hz, T = 5778 K",
        "u(ν,T) = (8πhν³/c³) × 1/(e^(hν/k_BT) - 1)",
        "Resultado: u ≈ 1.2 × 10⁻⁶ J·s/m³"
      ],
      "result": "1.2 × 10⁻⁶ J·s/m³"
    }
  },
  {
    "id": "cuantica-ejercicio-02",
    "groupId": "stefan-boltzmann",
    "title": "Radiación del Sol",
    "enunciado": "Calcula la intensidad radiada por el Sol (T = 5778 K).",
    "solution": {
      "steps": [
        "Datos: T = 5778 K, σ = 5.67 × 10⁻⁸ W/(m²·K⁴)",
        "I = σT⁴ = 5.67 × 10⁻⁸ × 5778⁴",
        "Resultado: I = 6.32 × 10⁷ W/m²"
      ],
      "result": "6.32 × 10⁷ W/m² (63.2 MW/m²)"
    }
  },
  {
    "id": "cuantica-ejercicio-03",
    "groupId": "wien-ley",
    "title": "Máximo del Sol",
    "enunciado": "Calcula la longitud de onda del máximo de emisión del Sol (T = 5778 K).",
    "solution": {
      "steps": [
        "Datos: T = 5778 K",
        "λ_max = 2.898 × 10⁻³ / T",
        "λ_max = 2.898 × 10⁻³ / 5778",
        "Resultado: λ_max = 501 nm (verde)"
      ],
      "result": "501 nm (luz verde)"
    }
  },
  {
    "id": "cuantica-ejercicio-04",
    "groupId": "einstein-calor",
    "title": "Calor Específico de Einstein",
    "enunciado": "Calcula C_V para 1 mol con θ_E = 240 K a T = 300 K.",
    "solution": {
      "steps": [
        "Datos: θ_E = 240 K, T = 300 K, x = θ_E/T = 0.8",
        "C_V = 3R x² e^x / (e^x - 1)²",
        "C_V = 3 × 8.314 × 0.64 × 2.23 / 1.51",
        "Resultado: C_V = 23.8 J/(mol·K)"
      ],
      "result": "23.8 J/(mol·K)"
    }
  },
  {
    "id": "cuantica-ejercicio-05",
    "groupId": "debye-calor",
    "title": "Ley T³ de Debye",
    "enunciado": "Calcula C_V para 1 mol con θ_D = 343 K a T = 50 K (límite de bajas T).",
    "solution": {
      "steps": [
        "Datos: θ_D = 343 K, T = 50 K",
        "T << θ_D, usar ley T³",
        "C_V = (12π⁴/5) R (T/θ_D)³",
        "C_V = 234.8 × 8.314 × (50/343)³",
        "Resultado: C_V = 6.5 J/(mol·K)"
      ],
      "result": "6.5 J/(mol·K)"
    }
  },
  {
    "id": "cuantica-ejercicio-06",
    "groupId": "energia-fermi",
    "title": "Energía de Fermi del Cobre",
    "enunciado": "Calcula E_F para Cu con n = 8.5 × 10²⁸ m⁻³.",
    "solution": {
      "steps": [
        "Datos: n = 8.5 × 10²⁸ m⁻³",
        "E_F = (ℏ²/2m)(3π²n)^(2/3)",
        "E_F = 1.13 × 10⁻¹⁸ J",
        "Resultado: E_F = 7.05 eV, T_F = 81800 K"
      ],
      "result": "7.05 eV (81800 K)"
    }
  },
  {
    "id": "cuantica-ejercicio-07",
    "groupId": "calor-electronico",
    "title": "Calor Específico Electrónico",
    "enunciado": "Calcula C_V^el para Cu a 300 K (E_F = 7.05 eV, n = 8.5 × 10²⁸ m⁻³, V = 10⁻⁶ m³).",
    "solution": {
      "steps": [
        "Datos: E_F = 1.13 × 10⁻¹⁸ J, T = 300 K",
        "C_V^el = (π²/2) n V k_B² T / E_F",
        "C_V^el = 1.57 × 8.5 × 10²⁸ × 10⁻⁶ × (1.381 × 10⁻²³)² × 300 / 1.13 × 10⁻¹⁸",
        "Resultado: C_V^el = 0.042 J/K"
      ],
      "result": "0.042 J/K"
    }
  },
  {
    "id": "cuantica-ejercicio-08",
    "groupId": "bec-temperatura",
    "title": "BEC de Rubidio-87",
    "enunciado": "Calcula T_c para ⁸⁷Rb con n = 10²⁰ m⁻³ (m = 1.443 × 10⁻²⁵ kg).",
    "solution": {
      "steps": [
        "Datos: n = 10²⁰ m⁻³, m = 1.443 × 10⁻²⁵ kg",
        "T_c = (2πℏ²/mk_B)(n/ζ(3/2))^(2/3)",
        "ζ(3/2) = 2.612",
        "Resultado: T_c = 200 nK"
      ],
      "result": "200 nK"
    }
  },
  {
    "id": "cuantica-ejercicio-09",
    "groupId": "numero-ocupacion-bose",
    "title": "Ocupación de Bosones",
    "enunciado": "Calcula n_BE para E = 10⁻²⁰ J, μ = -10⁻²¹ J a T = 300 K.",
    "solution": {
      "steps": [
        "Datos: E = 10⁻²⁰ J, μ = -10⁻²¹ J, T = 300 K",
        "n_BE = 1/(e^((E-μ)/k_BT) - 1)",
        "(E-μ)/k_BT = 2.66",
        "Resultado: n_BE = 0.074"
      ],
      "result": "0.074"
    }
  },
  {
    "id": "cuantica-ejercicio-10",
    "groupId": "numero-ocupacion-fermi",
    "title": "Ocupación de Fermiones",
    "enunciado": "Calcula n_FD para E = 1.1 × 10⁻¹⁸ J con E_F = 1.13 × 10⁻¹⁸ J a T = 300 K.",
    "solution": {
      "steps": [
        "Datos: E = 1.1 × 10⁻¹⁸ J, E_F = 1.13 × 10⁻¹⁸ J, T = 300 K",
        "n_FD = 1/(e^((E-E_F)/k_BT) + 1)",
        "(E-E_F)/k_BT = -7.24",
        "Resultado: n_FD = 0.999 (casi lleno)"
      ],
      "result": "0.999"
    }
  }
]
