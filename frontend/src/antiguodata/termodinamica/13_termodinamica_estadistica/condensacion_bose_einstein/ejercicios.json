    "title": "Longitud de onda térmica para ⁸⁷Rb",
    "enunciado": "Calcula λ_T para m = 1.443 × 10^{-25} kg, T = 2 × 10^{-7} K, k_B = 1.38 × 10^{-23} J/K, h = 6.626 × 10^{-34} J·s.",
    "solution": {
      "steps": [
        "Datos: m = 1.443 × 10^{-25} kg, T = 2 × 10^{-7} K, k_B = 1.38 × 10^{-23} J/K, h = 6.626 × 10^{-34} J·s",
        "λ_T = h / sqrt(2π m k_B T)",
        "λ_T = 6.626×10^{-34} / sqrt(2π×1.443×10^{-25}×1.38×10^{-23}×2×10^{-7})",
        "Resultado: λ_T ≈ 0.5 μm"
      ],
      "result": "0.5 μm"
    }
  },
  {
    "id": "bec-ejercicio-04",
    "groupId": "bec-fraccion",
    "title": "Fracción condensada a T dada",
    "enunciado": "Calcula N₀/N para T = 100 nK y T_c = 200 nK.",
    "solution": {
      "steps": [
        "Datos: T = 100 nK = 1 × 10^{-7} K, T_c = 200 nK = 2 × 10^{-7} K",
        "N₀/N = 1 - (T/T_c)^{3/2}",
        "N₀/N = 1 - (0.5)^{3/2}",
        "N₀/N = 1 - 0.354 = 0.646"
      ],
      "result": "0.646"
    }
  }
