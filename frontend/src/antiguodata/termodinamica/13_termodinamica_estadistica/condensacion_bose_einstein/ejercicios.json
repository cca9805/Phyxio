    "id": "bec-ejercicio-01",
    "groupId": "bec-distribucion",
    "title": "Cálculo de n_i para un estado dado",
    "enunciado": "Calcula n_i para ε_i = 1.5 × 10^{-21} J, μ = 0, k_B = 1.38 × 10^{-23} J/K, T = 300 nK.",
    "solution": {
      "steps": [
        "Datos: ε_i = 1.5 × 10^{-21} J, μ = 0, k_B = 1.38 × 10^{-23} J/K, T = 3 × 10^{-7} K",
        "n_i = 1 / [e^{(ε_i - μ)/(k_B T)} - 1]",
        "n_i = 1 / [e^{(1.5×10^{-21} - 0)/(1.38×10^{-23} × 3×10^{-7})} - 1]",
        "Resultado: n_i ≈ 1.2"
      ],
      "result": "1.2"
    }
  },
  {
