    "id": "boltzmann-ejercicio-01",
    "groupId": "boltzmann-ni",
    "title": "Distribución de Boltzmann: población de estado",
    "enunciado": "Calcula n_i para N = 1000, g_i = 2, ε_i = 2.5 × 10^{-21} J, T = 300 K, k_B = 1.38 × 10^{-23} J/K, Z = 10.",
    "solution": {
      "steps": [
        "Datos: N = 1000, g_i = 2, ε_i = 2.5 × 10^{-21} J, T = 300 K, k_B = 1.38 × 10^{-23} J/K, Z = 10",
        "n_i = (N / Z) g_i exp(-ε_i / (k_B T))",
        "n_i = (1000 / 10) × 2 × exp(-2.5×10^{-21} / (1.38×10^{-23} × 300))",
        "Resultado: n_i ≈ 200 × exp(-0.604) ≈ 109.5"
      ],
      "result": "n_i ≈ 109.5"
    }
  },
