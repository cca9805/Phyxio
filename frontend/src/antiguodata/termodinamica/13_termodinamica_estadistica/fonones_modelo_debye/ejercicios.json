		"title": "Temperatura de Debye para el cobre",
		"enunciado": "Calcula la temperatura de Debye para el cobre si v_s = 4760 m/s y n = 8.5 × 10^{28} m^{-3}.",
		"solution": {
			"steps": [
				"Datos: v_s = 4760 m/s, n = 8.5 * 10^28 m^-3, hbar = 1.0545718e-34 J*s, k_B = 1.380649e-23 J/K",
				"Theta_D = (hbar * v_s / k_B) * (6 * pi^2 * n)^(1/3)",
				"Theta_D = (1.0545718e-34 * 4760 / 1.380649e-23) * (6 * pi^2 * 8.5e28)^(1/3)",
				"Resultado: Theta_D ~= 343 K"
			],
			"result": "Theta_D ~= 343 K"
		}
