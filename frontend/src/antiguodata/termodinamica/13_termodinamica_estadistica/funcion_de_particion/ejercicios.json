    "id": "ejercicio-particion-energia-libre-01",
    "groupId": "funcion_de_particion",
    "title": "Energía Libre desde Z",
    "enunciado": "Un sistema tiene una función de partición Z = 1000 a temperatura T = 300 K. Calcula la energía libre de Helmholtz F usando F = -k_B * T * ln(Z).",
    "solution": {
      "steps": [
        "Datos: Z = 1000, T = 300 K, k_B = 1.381e-23 J/K",
        "Fórmula: F = -k_B * T * ln(Z)",
        "Sustitución: F = -(1.381e-23 J/K) * (300 K) * ln(1000)",
        "F = -(4.143e-21 J) * 6.908",
        "Resultado: F ≈ -2.86e-20 J"
      ],
      "result": "F ≈ -2.86e-20 J"
    }
  },
  {
    "id": "ejercicio-dos-niveles-01",
    "groupId": "dos-niveles-particion",
    "title": "Sistema de Dos Niveles a Baja Temperatura",
    "enunciado": "Un sistema de dos niveles tiene una separación de energía ε = 1 × 10⁻²⁰ J. Calcula la función de partición a T = 100 K.",
    "solution": {
      "steps": [
        "Datos: ε = 1 × 10⁻²⁰ J, T = 100 K, k_B = 1.381 × 10⁻²³ J/K",
        "Calcular β: β = 1/(k_B T) = 1/(1.381 × 10⁻²³ × 100) = 7.24 × 10²⁰ J⁻¹",
        "Calcular βε: βε = 7.24 × 10²⁰ × 1 × 10⁻²⁰ = 7.24",
        "Fórmula: Z = 1 + exp(-βε) = 1 + exp(-7.24)",
        "Z = 1 + 0.000715 ≈ 1.0007",
        "Resultado: Z ≈ 1.001 (nivel excitado casi desocupado)"
      ],
      "result": "Z ≈ 1.001"
    }
  },
  {
    "id": "ejercicio-dos-niveles-02",
    "groupId": "dos-niveles-particion",
    "title": "Sistema de Dos Niveles a Alta Temperatura",
    "enunciado": "El mismo sistema de dos niveles (ε = 1 × 10⁻²⁰ J) ahora a T = 1000 K. Calcula Z.",
    "solution": {
      "steps": [
        "Datos: ε = 1 × 10⁻²⁰ J, T = 1000 K",
        "Calcular β: β = 1/(k_B T) = 1/(1.381 × 10⁻²³ × 1000) = 7.24 × 10¹⁹ J⁻¹",
        "Calcular βε: βε = 7.24 × 10¹⁹ × 1 × 10⁻²⁰ = 0.724",
        "Z = 1 + exp(-0.724) = 1 + 0.485",
        "Resultado: Z ≈ 1.485 (ambos niveles significativamente poblados)"
      ],
      "result": "Z ≈ 1.485"
    }
  },
  {
    "id": "ejercicio-oscilador-armonico-01",
    "groupId": "oscilador-armonico-particion",
    "title": "Oscilador Armónico a Temperatura Ambiente",
    "enunciado": "Un oscilador armónico tiene frecuencia ω = 1 × 10¹⁴ rad/s. Calcula Z a T = 300 K.",
    "solution": {
      "steps": [
        "Datos: ω = 1 × 10¹⁴ rad/s, T = 300 K",
        "ℏ = 1.055 × 10⁻³⁴ J·s",
        "Calcular ℏω: ℏω = 1.055 × 10⁻³⁴ × 1 × 10¹⁴ = 1.055 × 10⁻²⁰ J",
        "Calcular βℏω: βℏω = (1.055 × 10⁻²⁰)/(1.381 × 10⁻²³ × 300) = 2.54",
        "Z = exp(-βℏω/2) / (1 - exp(-βℏω))",
        "Z = exp(-1.27) / (1 - exp(-2.54)) = 0.281 / 0.921",
        "Resultado: Z ≈ 0.305"
      ],
      "result": "Z ≈ 0.305"
    }
  },
  {
    "id": "ejercicio-particulas-independientes-01",
    "groupId": "particulas-independientes",
    "title": "Sistema de 3 Partículas Independientes",
    "enunciado": "Si la función de partición de una partícula es Z₁ = 10, calcula la función de partición de un sistema de N = 3 partículas indistinguibles.",
    "solution": {
      "steps": [
        "Datos: Z₁ = 10, N = 3",
        "Fórmula: Z_N = Z₁^N / N!",
        "Calcular Z₁^N: Z₁³ = 10³ = 1000",
        "Calcular N!: 3! = 6",
        "Z_N = 1000 / 6",
        "Resultado: Z_N ≈ 166.67"
      ],
      "result": "Z_N ≈ 166.67"
    }
  },
  {
    "id": "ejercicio-entropia-01",
    "groupId": "funcion-particion-entropia",
    "title": "Entropía desde Z y U",
    "enunciado": "Un sistema tiene Z = 500, U = 5 × 10⁻²⁰ J y T = 300 K. Calcula la entropía S.",
    "solution": {
      "steps": [
        "Datos: Z = 500, U = 5 × 10⁻²⁰ J, T = 300 K",
        "Fórmula: S = k_B ln(Z) + U/T",
        "Calcular k_B ln(Z): (1.381 × 10⁻²³) × ln(500) = 8.58 × 10⁻²³ J/K",
        "Calcular U/T: (5 × 10⁻²⁰) / 300 = 1.67 × 10⁻²² J/K",
        "S = 8.58 × 10⁻²³ + 1.67 × 10⁻²² = 2.53 × 10⁻²² J/K",
        "Resultado: S ≈ 2.53 × 10⁻²² J/K"
      ],
      "result": "S ≈ 2.53 × 10⁻²² J/K"
    }
  },
  {
    "id": "ejercicio-fluctuaciones-01",
    "groupId": "fluctuaciones-energia",
    "title": "Fluctuaciones de Energía",
    "enunciado": "Un sistema tiene C_V = 2 × 10⁻²² J/K a T = 300 K. Calcula la varianza de la energía ⟨(ΔE)²⟩.",
    "solution": {
      "steps": [
        "Datos: C_V = 2 × 10⁻²² J/K, T = 300 K",
        "Fórmula: ⟨(ΔE)²⟩ = k_B T² C_V",
        "Sustitución: ⟨(ΔE)²⟩ = (1.381 × 10⁻²³) × (300)² × (2 × 10⁻²²)",
        "⟨(ΔE)²⟩ = 1.381 × 10⁻²³ × 90000 × 2 × 10⁻²²",
        "⟨(ΔE)²⟩ = 2.49 × 10⁻³⁹ J²",
        "Desviación estándar: σ_E = √(2.49 × 10⁻³⁹) = 1.58 × 10⁻²⁰ J",
        "Resultado: ⟨(ΔE)²⟩ ≈ 2.49 × 10⁻³⁹ J²"
      ],
      "result": "⟨(ΔE)²⟩ ≈ 2.49 × 10⁻³⁹ J²"
    }
  },
  {
    "id": "ejercicio-presion-01",
    "groupId": "funcion-particion-presion",
    "title": "Presión desde Z",
    "enunciado": "Para un gas ideal, Z ∝ V^N. Si dZ/dV = N × Z/V, calcula la presión para N = 10²³, T = 300 K, V = 0.001 m³.",
    "solution": {
      "steps": [
        "Datos: N = 10²³, T = 300 K, V = 0.001 m³",
        "d(ln Z)/dV = (1/Z)(dZ/dV) = N/V",
        "Fórmula: P = k_B T × d(ln Z)/dV = k_B T × N/V",
        "P = (1.381 × 10⁻²³ J/K) × (300 K) × (10²³ / 0.001 m³)",
        "P = 4.143 × 10⁻²¹ × 10²⁶",
        "Resultado: P ≈ 4.14 × 10⁵ Pa (≈ 4 atm)"
      ],
      "result": "P ≈ 4.14 × 10⁵ Pa"
    }
  },
  {
    "id": "ejercicio-energia-interna-01",
    "groupId": "funcion-particion-energia-interna",
    "title": "Energía Interna desde Z",
    "enunciado": "Para un sistema con Z = 100 y dZ/dT = 2 K⁻¹ a T = 300 K, calcula la energía interna U.",
    "solution": {
      "steps": [
        "Datos: Z = 100, dZ/dT = 2 K⁻¹, T = 300 K",
        "Calcular d(ln Z)/dT: d(ln Z)/dT = (dZ/dT)/Z = 2/100 = 0.02 K⁻¹",
        "Fórmula: U = k_B T² × d(ln Z)/dT",
        "U = (1.381 × 10⁻²³ J/K) × (300 K)² × (0.02 K⁻¹)",
        "U = 1.381 × 10⁻²³ × 90000 × 0.02",
        "Resultado: U ≈ 2.49 × 10⁻²⁰ J"
      ],
      "result": "U ≈ 2.49 × 10⁻²⁰ J"
    }
  },
  {
    "id": "ejercicio-calor-especifico-01",
    "groupId": "calor-especifico-particion",
    "title": "Calor Específico desde Z",
    "enunciado": "Un sistema tiene d²(ln Z)/dβ² = 5 × 10⁻⁴⁰ J² a T = 300 K. Calcula C_V.",
    "solution": {
      "steps": [
        "Datos: d²(ln Z)/dβ² = 5 × 10⁻⁴⁰ J², T = 300 K",
        "Calcular β: β = 1/(k_B T) = 1/(1.381 × 10⁻²³ × 300) = 2.415 × 10²⁰ J⁻¹",
        "Fórmula: C_V = k_B β² × d²(ln Z)/dβ²",
        "C_V = (1.381 × 10⁻²³) × (2.415 × 10²⁰)² × (5 × 10⁻⁴⁰)",
        "C_V = 1.381 × 10⁻²³ × 5.832 × 10⁴⁰ × 5 × 10⁻⁴⁰",
        "Resultado: C_V ≈ 4.03 × 10⁻²² J/K"
      ],
      "result": "C_V ≈ 4.03 × 10⁻²² J/K"
    }
  }
]
