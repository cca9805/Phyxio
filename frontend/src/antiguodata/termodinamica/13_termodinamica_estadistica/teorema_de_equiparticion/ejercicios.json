    "id": "equiparticion-ejercicio-07",
    "groupId": "grados-libertad-activos",
    "title": "Grados de Libertad del H₂",
    "enunciado": "Determina cuántos grados de libertad están activos en H₂ a 300 K (θ_rot = 85.4 K, θ_vib = 6332 K).",
    "solution": {
      "steps": [
        "Datos: T = 300 K, θ_rot = 85.4 K, θ_vib = 6332 K",
        "Traslación: siempre activa → f_trans = 3",
        "Rotación: T > θ_rot (300 > 85.4) → f_rot = 2",
        "Vibración: T < θ_vib (300 < 6332) → f_vib = 0",
        "Total: f = 3 + 2 + 0 = 5"
      ],
      "result": "5 grados de libertad activos"
    }
