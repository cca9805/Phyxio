// frontend/src/v2/agent/graphMetadata.contract.js

export const GRAPH_TYPES = {
  COORD: "Coord",
  DCL: "Dcl",
  SVG: "Svg",
};

export const GRAPH_SEMANTIC_ROLES = {
  LAW_RELATIONSHIP: "law_relationship",
  MOTION_EVOLUTION: "motion_evolution",
  FORCE_BALANCE: "force_balance",
  FORCE_DECOMPOSITION: "force_decomposition",
  PHYSICAL_SCENE: "physical_scene",
  MODEL_VISUALIZATION: "model_visualization",
  COMPARISON: "comparison",
};

export const GRAPH_READING_MODES = {
  AXES_SLOPE_TREND: "axes_slope_trend",
  FORCES_BODY_RESULTANT: "forces_body_resultant",
  SCENE_GEOMETRY_MODEL: "scene_geometry_model",
};

export function normalizeGraphMetadata(metadata = {}) {
  return {
    graphId: metadata.graphId ?? null,
    type: metadata.type ?? null,
    title: metadata.title ?? "Gráfico",
    subtitle: metadata.subtitle ?? null,

    semanticRole: metadata.semanticRole ?? null,
    readingMode: metadata.readingMode ?? null,

    xMagnitude: metadata.xMagnitude ?? null,
    yMagnitude: metadata.yMagnitude ?? null,
    relation: metadata.relation ?? null,
    slopeMeaning: metadata.slopeMeaning ?? null,
    interceptMeaning: metadata.interceptMeaning ?? null,

    selectedObject: metadata.selectedObject ?? null,
    sceneId: metadata.sceneId ?? null,
    sceneLabel: metadata.sceneLabel ?? null,

    visibleMagnitudes: Array.isArray(metadata.visibleMagnitudes)
      ? metadata.visibleMagnitudes
      : [],

    visibleForces: Array.isArray(metadata.visibleForces)
      ? metadata.visibleForces
      : [],

    components: Array.isArray(metadata.components)
      ? metadata.components
      : [],

    physicalReading: metadata.physicalReading ?? null,
    modelConnection: metadata.modelConnection ?? null,
    formulaConnection: metadata.formulaConnection ?? null,

    recommendedTab: metadata.recommendedTab ?? null,

    agentHints: Array.isArray(metadata.agentHints)
      ? metadata.agentHints
      : [],

    commonMistakes: Array.isArray(metadata.commonMistakes)
      ? metadata.commonMistakes
      : [],
  };
}
