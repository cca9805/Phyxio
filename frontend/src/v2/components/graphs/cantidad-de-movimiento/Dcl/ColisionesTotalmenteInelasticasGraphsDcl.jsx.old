import { createDclGraph } from "../../graphFactories.jsx";
import profile from "@/v2/components/DCL/profiles/colisionesTotalmenteInelasticas.profile";

/**
 * DCL force declarations:
 * Fuerzas: peso, normal, impulso de contacto (F₁₂, F₂₁) — colisión totalmente inelástica
 * Forces: weight, normal, contact impulse (F₁₂, F₂₁) — perfectly inelastic collision
 * Force vectors: F_normal, F_peso (Weight), F_contacto (contact impulse)
 * Arrow directions follow Newton's third law action-reaction pairs.
 */

export default createDclGraph({
  displayName: "ColisionesTotalmenteInelasticasGraphsDcl",
  profile,
});

