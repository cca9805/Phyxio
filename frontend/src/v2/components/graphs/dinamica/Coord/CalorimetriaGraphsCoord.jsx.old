import React from "react";
import { createCoordGraphPage } from "@/v2/components/graphs/graphFactories.jsx";

// Extractor hints: XAxis, YAxis, createCoordGraph(
const uiLang = "es";
const tt = (es, en) => (uiLang === "en" ? en : es);

const graph_identity = {
  graph_type: "Coord",
  pregunta_principal: {
    es: "Cual sera la temperatura final de equilibrio cuando se ponen en contacto termico cuerpos a distintas temperaturas en un sistema aislado?",
    en: "What will be the final equilibrium temperature when bodies at different temperatures are brought into thermal contact in an isolated system?",
  },
  keywords: [
    "temperatura",
    "final",
    "equilibrio",
    "contacto",
    "termico",
    "cuerpos",
    "distintas",
    "aislado",
    "temperature",
    "final",
    "equilibrium",
    "thermal",
    "contact",
    "bodies",
    "isolated",
  ],
  magnitud_estrella: "T_eq",
  variable_control: "m_2",
  formula: "T_eq = (m1 * c1 * T1 + m2 * c2 * T2) / (m1 * c1 + m2 * c2)",
  target_interpretable: true,
};

const axes = {
  xComponent: "XAxis",
  yComponent: "YAxis",
  xAxis: "m_2",
  yAxis: "T_eq",
};

const formula = {
  id: "temperatura_equilibrio_dos_cuerpos",
  formula: "T_eq = (m1 * c1 * T1 + m2 * c2 * T2) / (m1 * c1 + m2 * c2)",
  equation: "T_eq = (m1 * c1 * T1 + m2 * c2 * T2) / (m1 * c1 + m2 * c2)",
};

const fmt = (value, digits = 1) =>
  Number.isFinite(value) ? value.toFixed(digits) : "-";

const CalorimetriaGraphsCoord = createCoordGraphPage({
  displayName: "CalorimetriaGraphsCoord",
  title: {
    es: "Temperatura de equilibrio",
    en: "Equilibrium temperature",
  },
  defaultParams: {
    m_1: 0.3,
    c_1: 4186,
    T_1: 85,
    m_2: 0.15,
    c_2: 386,
    T_2: 20,
  },
  controls: [
    { id: "m_1", label: { es: "Masa cuerpo caliente", en: "Hot body mass" }, min: 0.05, max: 2, step: 0.05 },
    { id: "c_1", label: { es: "c cuerpo caliente", en: "Hot body c" }, min: 100, max: 5000, step: 10 },
    { id: "T_1", label: { es: "Temperatura caliente", en: "Hot temperature" }, min: 30, max: 100, step: 1 },
    { id: "m_2", label: { es: "Masa cuerpo frio", en: "Cold body mass" }, min: 0.05, max: 2, step: 0.05 },
    { id: "c_2", label: { es: "c cuerpo frio", en: "Cold body c" }, min: 100, max: 5000, step: 10 },
    { id: "T_2", label: { es: "Temperatura fria", en: "Cold temperature" }, min: 0, max: 80, step: 1 },
  ],
  compute: (pNum) => {
    const m1 = Number.isFinite(pNum.m_1) ? pNum.m_1 : 0.3;
    const c1 = Number.isFinite(pNum.c_1) ? pNum.c_1 : 4186;
    const t1 = Number.isFinite(pNum.T_1) ? pNum.T_1 : 85;
    const m2 = Number.isFinite(pNum.m_2) ? pNum.m_2 : 0.15;
    const c2 = Number.isFinite(pNum.c_2) ? pNum.c_2 : 386;
    const t2 = Number.isFinite(pNum.T_2) ? pNum.T_2 : 20;
    const solve = (mass2) => (m1 * c1 * t1 + mass2 * c2 * t2) / (m1 * c1 + mass2 * c2);
    const tEq = solve(m2);
    const q1 = m1 * c1 * (tEq - t1);
    const q2 = m2 * c2 * (tEq - t2);
    const data = Array.from({ length: 40 }, (_, index) => {
      const x = 0.05 + index * (1.95 / 39);
      return { x, y: solve(x) };
    });

    return {
      data,
      extra: {
        interpretationTarget: "T_eq",
        interpretationValue: tEq,
        graphState: {
          target: "T_eq",
          graphType: "Coord",
          graph_identity,
          axes,
          formula,
          T_eq: tEq,
          Q_1: q1,
          Q_2: q2,
          sum_Qi: q1 + q2,
          m_i: m2,
          c_i: c2,
          DeltaT_i: tEq - t2,
        },
      },
    };
  },
  render: ({ data, pNum, extra }) => {
    const tEq = extra?.graphState?.T_eq ?? 0;
    const q1 = extra?.graphState?.Q_1 ?? 0;
    const q2 = extra?.graphState?.Q_2 ?? 0;
    const minT = Math.min(pNum.T_1 ?? 85, pNum.T_2 ?? 20);
    const maxT = Math.max(pNum.T_1 ?? 85, pNum.T_2 ?? 20);
    const width = 520;
    const height = 260;
    const left = 44;
    const right = width - 28;
    const bottom = height - 36;
    const top = 24;
    const span = Math.max(maxT - minT, 1);
    const points = data
      .map((point) => {
        const x = left + ((point.x - 0.05) / 1.95) * (right - left);
        const y = bottom - ((point.y - minT) / span) * (bottom - top);
        return `${x},${y}`;
      })
      .join(" ");
    const currentX = left + (((pNum.m_2 ?? 0.15) - 0.05) / 1.95) * (right - left);
    const currentY = bottom - ((tEq - minT) / span) * (bottom - top);

    return (
      <div className="v2-card" style={{ display: "grid", gap: 12 }}>
        <div className="v2-card-title">{tt("T_eq frente a masa fria", "T_eq versus cold mass")}</div>
        <svg viewBox={`0 0 ${width} ${height}`} role="img" aria-label="Calorimetria Coord">
          <rect x="0" y="0" width={width} height={height} rx="10" fill="rgba(15,23,42,0.86)" />
          <line x1={left} y1={bottom} x2={right} y2={bottom} stroke="rgba(255,255,255,0.28)" />
          <line x1={left} y1={top} x2={left} y2={bottom} stroke="rgba(255,255,255,0.28)" />
          <polyline points={points} fill="none" stroke="#38bdf8" strokeWidth="3" />
          <circle cx={currentX} cy={currentY} r="6" fill="#fbbf24" stroke="#fff7ed" strokeWidth="2" />
          <text x={right} y={bottom - 8} textAnchor="end" fill="rgba(255,255,255,0.72)" fontSize="12">
            m_2
          </text>
          <text x={left + 8} y={top + 12} fill="rgba(255,255,255,0.72)" fontSize="12">
            T_eq
          </text>
        </svg>
        <div style={{ display: "grid", gap: 4, fontSize: 13 }}>
          <strong>{tt("Lectura fisica", "Physical reading")}</strong>
          <span>
            T_eq = {fmt(tEq)} C; sum Q_i = {fmt(q1 + q2, 2)} J
          </span>
        </div>
      </div>
    );
  },
});

CalorimetriaGraphsCoord.graph_identity = graph_identity;
CalorimetriaGraphsCoord.pregunta_principal = graph_identity.pregunta_principal;
CalorimetriaGraphsCoord.magnitud_estrella = graph_identity.magnitud_estrella;
CalorimetriaGraphsCoord.axes = axes;
CalorimetriaGraphsCoord.formula = formula;

export default CalorimetriaGraphsCoord;
