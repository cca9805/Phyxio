import React from "react";
import { createCoordGraphPage } from "@/v2/components/graphs/graphFactories.jsx";

// Extractor hints: XAxis, YAxis, createCoordGraph(
const uiLang = "es";
const tt = (es, en) => (uiLang === "en" ? en : es);

const graph_identity = {
  graph_type: "Coord",
  pregunta_principal: {
    es: "Cuanta energia se necesita para cambiar el estado de una sustancia y por que la temperatura no varia durante la transicion?",
    en: "How much energy is needed to change the state of a substance, and why does temperature not change during the transition?",
  },
  keywords: [
    "energia",
    "estado",
    "sustancia",
    "temperatura",
    "transicion",
    "calor",
    "latente",
    "energy",
    "state",
    "substance",
    "temperature",
    "transition",
    "heat",
    "latent",
  ],
  magnitud_estrella: "Q_lat",
  variable_control: "m",
  formula: "Q_lat = m * L",
  target_interpretable: true,
};

const axes = {
  xComponent: "XAxis",
  yComponent: "YAxis",
  xAxis: "m",
  yAxis: "Q_lat",
};

const formula = {
  id: "calor_latente_general",
  formula: "Q_lat = m * L",
  equation: "Q_lat = m * L",
};

const fmt = (value, digits = 1) =>
  Number.isFinite(value) ? value.toFixed(digits) : "-";

const CambiosDeEstadoGraphsCoord = createCoordGraphPage({
  displayName: "CambiosDeEstadoGraphsCoord",
  title: {
    es: "Calor latente",
    en: "Latent heat",
  },
  defaultParams: {
    m: 0.3,
    L: 334000,
    T_trans: 0,
  },
  controls: [
    { id: "m", label: { es: "Masa", en: "Mass" }, min: 0.05, max: 2, step: 0.05 },
    { id: "L", label: { es: "Calor latente especifico", en: "Specific latent heat" }, min: 100000, max: 2500000, step: 10000 },
    { id: "T_trans", label: { es: "Temperatura de transicion", en: "Transition temperature" }, min: -40, max: 120, step: 1 },
  ],
  compute: (pNum) => {
    const mass = Number.isFinite(pNum.m) ? pNum.m : 0.3;
    const latent = Number.isFinite(pNum.L) ? pNum.L : 334000;
    const transitionTemp = Number.isFinite(pNum.T_trans) ? pNum.T_trans : 0;
    const solve = (xMass) => xMass * latent;
    const qLat = solve(mass);
    const data = Array.from({ length: 40 }, (_, index) => {
      const x = 0.05 + index * (1.95 / 39);
      return { x, y: solve(x) };
    });

    return {
      data,
      extra: {
        interpretationTarget: "Q_lat",
        interpretationValue: qLat,
        graphState: {
          target: "Q_lat",
          graphType: "Coord",
          graph_identity,
          axes,
          formula,
          Q_lat: qLat,
          m: mass,
          L: latent,
          T_trans: transitionTemp,
        },
      },
    };
  },
  render: ({ data, pNum, extra }) => {
    const qLat = extra?.graphState?.Q_lat ?? 0;
    const latent = pNum.L ?? 334000;
    const width = 520;
    const height = 260;
    const left = 48;
    const right = width - 28;
    const bottom = height - 36;
    const top = 24;
    const maxY = Math.max(2 * latent, 1);
    const points = data
      .map((point) => {
        const x = left + ((point.x - 0.05) / 1.95) * (right - left);
        const y = bottom - (point.y / maxY) * (bottom - top);
        return `${x},${y}`;
      })
      .join(" ");
    const currentX = left + (((pNum.m ?? 0.3) - 0.05) / 1.95) * (right - left);
    const currentY = bottom - (qLat / maxY) * (bottom - top);

    return (
      <div className="v2-card" style={{ display: "grid", gap: 12 }}>
        <div className="v2-card-title">{tt("Q_lat frente a masa", "Q_lat versus mass")}</div>
        <svg viewBox={`0 0 ${width} ${height}`} role="img" aria-label="Cambios de estado Coord">
          <rect x="0" y="0" width={width} height={height} rx="10" fill="rgba(15,23,42,0.86)" />
          <line x1={left} y1={bottom} x2={right} y2={bottom} stroke="rgba(255,255,255,0.28)" />
          <line x1={left} y1={top} x2={left} y2={bottom} stroke="rgba(255,255,255,0.28)" />
          <polyline points={points} fill="none" stroke="#22c55e" strokeWidth="3" />
          <circle cx={currentX} cy={currentY} r="6" fill="#fbbf24" stroke="#fff7ed" strokeWidth="2" />
          <text x={right} y={bottom - 8} textAnchor="end" fill="rgba(255,255,255,0.72)" fontSize="12">
            m
          </text>
          <text x={left + 8} y={top + 12} fill="rgba(255,255,255,0.72)" fontSize="12">
            Q_lat
          </text>
        </svg>
        <div style={{ display: "grid", gap: 4, fontSize: 13 }}>
          <strong>{tt("Lectura fisica", "Physical reading")}</strong>
          <span>
            Q_lat = {fmt(qLat / 1000, 1)} kJ; T_trans = {fmt(pNum.T_trans ?? 0, 0)} C
          </span>
        </div>
      </div>
    );
  },
});

CambiosDeEstadoGraphsCoord.graph_identity = graph_identity;
CambiosDeEstadoGraphsCoord.pregunta_principal = graph_identity.pregunta_principal;
CambiosDeEstadoGraphsCoord.magnitud_estrella = graph_identity.magnitud_estrella;
CambiosDeEstadoGraphsCoord.axes = axes;
CambiosDeEstadoGraphsCoord.formula = formula;

export default CambiosDeEstadoGraphsCoord;
