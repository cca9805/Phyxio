import React from "react";
import { createCoordGraphPage } from "@/v2/components/graphs/graphFactories.jsx";

// Extractor hints: XAxis, YAxis, createCoordGraph(
const uiLang = "es";
const tt = (es, en) => (uiLang === "en" ? en : es);

const graph_identity = {
  graph_type: "Coord",
  pregunta_principal: {
    es: "Como se cuantifica la irreversibilidad de un proceso termodinamico mediante la entropia generada del universo?",
    en: "How is the irreversibility of a thermodynamic process quantified through generated entropy of the universe?",
  },
  keywords: [
    "irreversibilidad",
    "proceso",
    "termodinamico",
    "entropia",
    "generada",
    "universo",
    "irreversibility",
    "process",
    "entropy",
    "generated",
    "universe",
  ],
  magnitud_estrella: "S_gen",
  variable_control: "T_sis",
  formula: "S_gen = Q_sis * (1/T_ent - 1/T_sis)",
  target_interpretable: true,
};

const axes = {
  xComponent: "XAxis",
  yComponent: "YAxis",
  xAxis: "T_sis - T_ent",
  yAxis: "S_gen",
};

const formula = {
  id: "generacion_entropia_transferencia_calor",
  formula: "S_gen = Q_sis * (1/T_ent - 1/T_sis)",
  equation: "S_gen = Q_sis * (1/T_ent - 1/T_sis)",
};

const fmt = (value, digits = 1) =>
  Number.isFinite(value) ? value.toFixed(digits) : "-";

const ProcesosIrreversiblesGraphsCoord = createCoordGraphPage({
  displayName: "ProcesosIrreversiblesGraphsCoord",
  title: {
    es: "Entropia generada por gradiente termico",
    en: "Entropy generated by thermal gradient",
  },
  defaultParams: {
    Q_sis: 1000,
    T_ent: 300,
    T_sis: 500,
  },
  controls: [
    { id: "Q_sis", label: { es: "Calor transferido", en: "Transferred heat" }, min: 100, max: 5000, step: 100 },
    { id: "T_ent", label: { es: "Temperatura entorno", en: "Surroundings temperature" }, min: 250, max: 450, step: 5 },
    { id: "T_sis", label: { es: "Temperatura sistema", en: "System temperature" }, min: 300, max: 900, step: 5 },
  ],
  compute: (pNum) => {
    const q = Number.isFinite(pNum.Q_sis) ? pNum.Q_sis : 1000;
    const tent = Number.isFinite(pNum.T_ent) && pNum.T_ent > 0 ? pNum.T_ent : 300;
    const tsis = Number.isFinite(pNum.T_sis) && pNum.T_sis > 0 ? pNum.T_sis : 500;
    const maxDelta = Math.max(1, tsis - tent);
    const data = Array.from({ length: 36 }, (_, index) => {
      const frac = index / 35;
      const tHot = tent + maxDelta * frac;
      const sGen = Math.max(0, q * (1 / tent - 1 / tHot));
      return { x: tHot - tent, y: sGen };
    });
    const sGen = Math.max(0, q * (1 / tent - 1 / tsis));

    return {
      data,
      extra: {
        interpretationTarget: "S_gen",
        interpretationValue: sGen,
        graphState: {
          target: "S_gen",
          graphType: "Coord",
          graph_identity,
          axes,
          formula,
          S_gen: sGen,
          DeltaS_univ: sGen,
          Q_sis: q,
          T_ent: tent,
          T_sis: tsis,
          gradient: Math.max(0, tsis - tent),
        },
      },
    };
  },
  render: ({ data, extra }) => {
    const state = extra?.graphState ?? {};
    const width = 520;
    const height = 260;
    const maxX = Math.max(...data.map((point) => point.x), 1);
    const maxY = Math.max(...data.map((point) => point.y), 1);
    const points = data
      .map((point) => {
        const x = 42 + (point.x / maxX) * (width - 84);
        const y = height - 34 - (point.y / maxY) * (height - 68);
        return `${x},${y}`;
      })
      .join(" ");

    return (
      <div className="v2-card" style={{ display: "grid", gap: 12 }}>
        <div className="v2-card-title">{tt("Irreversibilidad y S_gen", "Irreversibility and S_gen")}</div>
        <svg viewBox={`0 0 ${width} ${height}`} role="img" aria-label="Procesos irreversibles Coord">
          <rect x="0" y="0" width={width} height={height} rx="10" fill="rgba(15,23,42,0.86)" />
          <line x1="38" y1={height - 32} x2={width - 28} y2={height - 32} stroke="rgba(255,255,255,0.28)" />
          <line x1="42" y1="24" x2="42" y2={height - 28} stroke="rgba(255,255,255,0.28)" />
          <polyline points={points} fill="none" stroke="#f97316" strokeWidth="3" />
          <circle cx="42" cy={height - 34} r="4" fill="#22c55e" />
          <text x={width - 34} y={height - 42} textAnchor="end" fill="rgba(255,255,255,0.72)" fontSize="12">
            T_sis - T_ent
          </text>
          <text x="52" y="38" fill="rgba(255,255,255,0.72)" fontSize="12">
            S_gen
          </text>
        </svg>
        <div style={{ display: "grid", gap: 4, fontSize: 13 }}>
          <strong>{tt("Lectura fisica", "Physical reading")}</strong>
          <span>
            T_sis = {fmt(state.T_sis, 0)} K; T_ent = {fmt(state.T_ent, 0)} K; S_gen = {fmt(state.S_gen, 2)} J/K
          </span>
        </div>
      </div>
    );
  },
});

ProcesosIrreversiblesGraphsCoord.graph_identity = graph_identity;
ProcesosIrreversiblesGraphsCoord.pregunta_principal = graph_identity.pregunta_principal;
ProcesosIrreversiblesGraphsCoord.magnitud_estrella = graph_identity.magnitud_estrella;
ProcesosIrreversiblesGraphsCoord.axes = axes;
ProcesosIrreversiblesGraphsCoord.formula = formula;

export default ProcesosIrreversiblesGraphsCoord;
