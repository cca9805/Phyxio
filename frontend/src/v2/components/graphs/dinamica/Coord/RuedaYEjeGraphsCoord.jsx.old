import React, { useMemo, useCallback } from "react";
import {
  ResponsiveContainer,
  LineChart,
  Line,
  XAxis,
  YAxis,
  CartesianGrid,
  Tooltip,
  ReferenceDot,
  ReferenceLine,
  Legend,
} from "recharts";
import MathInline from "@/v2/components/shared/MathInline";
import { useExperimentParams } from "@/v2/components/graphs_shared/experiment/useExperimentParams";

const clamp = (n, a, b) => Math.max(a, Math.min(b, n));
const toNum = (v, fb) => {
  const n = typeof v === "number" ? v : Number(String(v ?? "").replace(",", "."));
  return Number.isFinite(n) ? n : fb;
};

/**
 * Genera la curva VM vs R/r para los modelos ideal y real.
 * x = R/r ratio desde 1 hasta ratioMax.
 */
function buildData(eta, ratioMax) {
  const out = [];
  for (let ratio = 1; ratio <= ratioMax; ratio += 0.25) {
    out.push({
      ratio: parseFloat(ratio.toFixed(2)),
      VM_ideal: ratio,
      VM_real: eta * ratio,
    });
  }
  return out;
}

function Pill({ active, children, onClick }) {
  return (
    <button
      type="button"
      onClick={onClick}
      style={{
        padding: "8px 10px",
        borderRadius: 14,
        border: "1px solid rgba(255,255,255,0.14)",
        background: active ? "rgba(99,102,241,0.25)" : "rgba(0,0,0,0.35)",
        color: "rgba(255,255,255,0.90)",
        fontWeight: 900,
        cursor: "pointer",
      }}
    >
      {children}
    </button>
  );
}

export default function RuedaYEjeGraphsCoord(props) {
  const uiLang = props.lang === "en" ? "en" : "es";
  const decSep = uiLang === "en" ? "." : ",";
  const fmt = (n, d = 2) =>
    Number.isFinite(n) ? n.toFixed(d).replace(".", decSep) : "-";

  const tt = (es, en) => (uiLang === "en" ? en : es);

  const p = props.params ?? props.sharedParams ?? {};

  const schema = useMemo(
    () => [
      { key: "R", aliases: ["radio_rueda"], default: toNum(p.R ?? p.radio_rueda, 0.25) },
      { key: "r", aliases: ["radio_eje"], default: toNum(p.r ?? p.radio_eje, 0.025) },
      { key: "eta", aliases: ["rendimiento"], default: toNum(p.eta ?? p.rendimiento, 0.8) },
      { key: "ratioMax", aliases: ["ratio_max"], default: toNum(p.ratioMax ?? p.ratio_max, 20) },
      { key: "showIdeal", aliases: ["mostrarIdeal"], default: p.showIdeal ?? true },
      { key: "showReal", aliases: ["mostrarReal"], default: p.showReal ?? true },
    ],
    [p.R, p.radio_rueda, p.r, p.radio_eje, p.eta, p.rendimiento, p.ratioMax, p.ratio_max, p.showIdeal, p.showReal]
  );

  const exp = useExperimentParams({ params: p, schema, modeDefault: "experiment" });
  const ep = exp.effectiveParams;

  const R = clamp(toNum(ep.R, 0.25), 0.01, 10);
  const r = clamp(toNum(ep.r, 0.025), 0.001, R - 0.001);
  const eta = clamp(toNum(ep.eta, 0.8), 0.01, 1.0);
  const ratioMax = clamp(Math.round(toNum(ep.ratioMax, 20)), 5, 50);
  const showIdeal = !!ep.showIdeal;
  const showReal = !!ep.showReal;

  const currentRatio = R / r;
  const VM_ideal = currentRatio;
  const VM_real = eta * currentRatio;

  const data = useMemo(() => buildData(eta, ratioMax), [eta, ratioMax]);

  const setValue = useCallback(
    (k, v) => {
      exp.startExperiment();
      exp.setValue(k, v);
    },
    [exp]
  );

  return (
    <div style={{ display: "grid", gap: 12 }}>
      <div className="v2-card" style={{ padding: 12 }}>
        <div className="v2-card-title">
          {tt("Ventaja mecánica vs razón de radios R/r", "Mechanical advantage vs radius ratio R/r")}
        </div>
        <div className="muted" style={{ marginTop: 6 }}>
          <MathInline latex={"VM = R/r \\quad (\\text{ideal}), \\quad VM_{real} = \\eta \\cdot R/r"} />
        </div>

        <div style={{ display: "flex", flexDirection: "column", gap: 12, marginTop: 10 }}>
          <div
            style={{
              display: "flex",
              gap: 10,
              flexWrap: "wrap",
              alignItems: "center",
              padding: "8px 12px",
              borderRadius: 10,
              border: "1px solid rgba(59,130,246,0.2)",
              background: "rgba(59,130,246,0.08)",
            }}
          >
            <div style={{ display: "flex", gap: 6, alignItems: "center" }}>
              <span style={{ fontSize: 13, opacity: 0.85 }}>R (m)</span>
              <input
                className="form-control"
                style={{ width: 96 }}
                value={fmt(R, 3).replace(",", ".")}
                onChange={(e) => setValue("R", e.target.value)}
              />
            </div>
            <div style={{ display: "flex", gap: 6, alignItems: "center" }}>
              <span style={{ fontSize: 13, opacity: 0.85 }}>r (m)</span>
              <input
                className="form-control"
                style={{ width: 96 }}
                value={fmt(r, 3).replace(",", ".")}
                onChange={(e) => setValue("r", e.target.value)}
              />
            </div>
            <div style={{ display: "flex", gap: 6, alignItems: "center" }}>
              <span style={{ fontSize: 13, opacity: 0.85 }}>eta</span>
              <input
                className="form-control"
                style={{ width: 90 }}
                value={fmt(eta, 2).replace(",", ".")}
                onChange={(e) => setValue("eta", e.target.value)}
              />
            </div>
            <button
              type="button"
              onClick={exp.resetToCalculator}
              style={{
                marginLeft: "auto",
                padding: "8px 10px",
                borderRadius: 14,
                border: "1px solid rgba(255,255,255,0.14)",
                background: "rgba(0,0,0,0.35)",
                color: "rgba(255,255,255,0.88)",
                fontWeight: 900,
                cursor: "pointer",
              }}
            >
              {tt("Seguir calculadora", "Follow calculator")}
            </button>
          </div>

          <div
            style={{
              display: "flex",
              gap: 10,
              flexWrap: "wrap",
              alignItems: "center",
              padding: "8px 12px",
              borderRadius: 10,
              border: "1px solid rgba(2,132,199,0.22)",
              background: "rgba(2,132,199,0.10)",
            }}
          >
            <Pill active={showIdeal} onClick={() => setValue("showIdeal", !showIdeal)}>
              {tt("Ideal", "Ideal")}
            </Pill>
            <Pill active={showReal} onClick={() => setValue("showReal", !showReal)}>
              {tt("Real (eta)", "Real (eta)")}
            </Pill>
          </div>

          <div className="v2-panel" style={{ padding: 12 }}>
            <div style={{ fontSize: 13, opacity: 0.9, lineHeight: 1.5 }}>
              R/r = <b>{fmt(currentRatio, 2)}</b> &nbsp;|&nbsp;
              VM{tt(" ideal", " ideal")} = <b>{fmt(VM_ideal, 2)}</b> &nbsp;|&nbsp;
              VM{tt(" real", " real")} = <b>{fmt(VM_real, 2)}</b> &nbsp;|&nbsp;
              eta = <b>{fmt(eta, 2)}</b>
            </div>
          </div>
        </div>
      </div>

      <div className="v2-card" style={{ padding: 12 }}>
        <div className="v2-card-title">
          {tt("Ventaja mecánica en función de R/r", "Mechanical advantage as a function of R/r")}
        </div>
        <div style={{ width: "100%", height: 350, marginTop: 10 }}>
          <ResponsiveContainer>
            <LineChart data={data} margin={{ top: 10, right: 18, left: 10, bottom: 10 }}>
              <CartesianGrid strokeDasharray="4 4" />
              <XAxis
                dataKey="ratio"
                type="number"
                domain={[1, ratioMax]}
                label={{ value: "R/r", position: "insideBottomRight", offset: -5 }}
              />
              <YAxis
                tickFormatter={(v) => fmt(v, 1)}
                label={{ value: "VM", angle: -90, position: "insideLeft" }}
              />
              <Tooltip
                formatter={(value, name) => [fmt(value, 3), name]}
                labelFormatter={(v) => `R/r = ${typeof v === "number" ? v.toFixed(2) : v}`}
              />
              <Legend />
              <ReferenceLine y={0} stroke="rgba(255,255,255,0.20)" />
              {showIdeal ? (
                <Line
                  type="monotone"
                  dataKey="VM_ideal"
                  name={tt("VM ideal", "VM ideal")}
                  stroke="#60a5fa"
                  strokeWidth={2}
                  dot={false}
                />
              ) : null}
              {showReal ? (
                <Line
                  type="monotone"
                  dataKey="VM_real"
                  name={tt("VM real", "VM real")}
                  stroke="#34d399"
                  strokeWidth={2}
                  dot={false}
                />
              ) : null}
              {showIdeal ? (
                <ReferenceDot x={currentRatio} y={VM_ideal} r={6} fill="#60a5fa" stroke="none" />
              ) : null}
              {showReal ? (
                <ReferenceDot x={currentRatio} y={VM_real} r={6} fill="#34d399" stroke="none" />
              ) : null}
            </LineChart>
          </ResponsiveContainer>
        </div>
      </div>
    </div>
  );
}
