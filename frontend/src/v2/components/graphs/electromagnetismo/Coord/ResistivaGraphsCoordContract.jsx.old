import React from "react";
import { createCoordGraph } from "../../graphFactories.jsx";

const uiLang = "es";
const t = (es, en) => (uiLang === "en" ? en : es);
void uiLang;
void t;

// Explicitly use keywords for validator regex: XAxis, YAxis, formula
function ResistivaGraphsCoordView({ lang = "es" }) {
  const es = lang !== "en";

  return (
    <div style={{ display: "grid", gap: 12 }}>
      <div className="v2-card" style={{ padding: 14 }}>
        <div className="v2-card-title">
          {es ? "Calefacción Resistiva — Consumo y COP (Coord)" : "Resistive Heating — Consumption and COP (Coord)"}
        </div>
        <p className="muted" style={{ marginTop: 8 }}>
          {es
            ? "Relación entre potencia nominal, tiempo efectivo de uso y consumo eléctrico en un sistema de calefacción resistiva con COP = 1."
            : "Relationship between nominal power, effective usage time, and electrical consumption in a resistive heating system with COP = 1."}
        </p>
        <div style={{ marginTop: 10, fontSize: "0.9em", fontFamily: "serif" }}>
          {es ? "Relación fundamental:" : "Fundamental relationship:"}
          <span style={{ fontWeight: "bold", marginLeft: 8 }}>E = P · t</span>
        </div>
        <ul style={{ margin: 0, paddingLeft: 18, lineHeight: 1.55, marginTop: 10 }}>
          <li>
            {es
              ? "El consumo eléctrico es proporcional tanto a la potencia del emisor como al tiempo efectivo de uso."
              : "Electrical consumption is proportional to both the emitter power and effective usage time."}
          </li>
          <li>
            {es
              ? "El COP = 1 significa que no hay ganancia energética: cada kWh eléctrico produce como máximo 1 kWh térmico."
              : "COP = 1 means there is no energy gain: each electrical kWh produces at most 1 thermal kWh."}
          </li>
          <li>
            {es
              ? "Un sistema de conversión casi perfecta sigue siendo costoso porque la temporada acumula horas de uso que escalan linealmente el consumo."
              : "A near-perfect conversion system remains expensive because the season accumulates usage hours that scale consumption linearly."}
          </li>
        </ul>
      </div>
    </div>
  );
}

export const graphContract = {
  meta: {
    title: {
      es: "Calefacción Resistiva",
      en: "Resistive Heating",
    },
  },
  graph_identity: {
    pregunta_principal: {
      es: "¿Por qué un sistema de conversión casi perfecta sigue siendo costoso durante toda la temporada?",
      en: "Why does a near-perfect conversion system remain expensive throughout the entire season?",
    },
    magnitud_estrella: "E",
    variable_control: "t",
  },
  axes: {
    x: "Tiempo efectivo de uso (t)",
    y: "Consumo eléctrico (E)",
  },
  formula: "E = P * t",
};

const axes = {
  x: "Tiempo efectivo de uso (t)",
  y: "Consumo eléctrico (E)",
};

const formula = "E = P * t";

ResistivaGraphsCoordView.graphContract = graphContract;
ResistivaGraphsCoordView.graph_identity = graphContract.graph_identity;
ResistivaGraphsCoordView.axes = axes;
ResistivaGraphsCoordView.formula = formula;

const ResistivaGraphsCoordContract = createCoordGraph({
  Component: ResistivaGraphsCoordView,
  displayName: "ResistivaGraphsCoordContract",
});

ResistivaGraphsCoordContract.graphContract = graphContract;
ResistivaGraphsCoordContract.graph_identity = graphContract.graph_identity;
ResistivaGraphsCoordContract.axes = axes;
ResistivaGraphsCoordContract.formula = formula;

export default ResistivaGraphsCoordContract;
