import React from "react";

function InterpretacionFisicaGraphsSvgView({ lang = "es" }) {
  const es = lang !== "en";

  return (
    <div className="v2-card" style={{ padding: 14 }}>
      <div className="v2-card-title">
        {es ? "Representación de Ondas (Svg)" : "Wave Representation (Svg)"}
      </div>
      <p style={{ marginTop: 8 }}>
        {es
          ? "Esquema conceptual de la propagación transversal de campos E y B."
          : "Conceptual scheme of E and B fields transverse propagation."}
      </p>
      <div style={{ background: "#eee", height: 200, display: "flex", alignItems: "center", justifyContent: "center", borderRadius: 8 }}>
        {es ? "Simulación de Onda Maxwell" : "Maxwell Wave Simulation"}
      </div>
    </div>
  );
}

export const graphContract = {
  meta: {
    title: {
      es: "Esquema de Ondas",
      en: "Wave Scheme",
    },
  },
  graph_identity: {
    pregunta_principal: {
      es: "¿Cómo se unifican la luz, la electricidad y el magnetismo en un solo marco conceptual?",
      en: "How are light, electricity, and magnetism unified in a single conceptual framework?",
    },
    magnitud_estrella: "vector_de_poynting",
    variable_control: "amplitud_del_campo_electrico",
  },
  graph_infocards: {
    cards: [
      {
        id: "poynting",
        title: { es: "Flujo de energía", en: "Energy Flow" },
        text: { 
          es: "El vector de Poynting describe la dirección y magnitud del transporte energético.",
          en: "The Poynting vector describes the direction and magnitude of energy transport."
        }
      }
    ]
  }
};

InterpretacionFisicaGraphsSvgView.graphContract = graphContract;
InterpretacionFisicaGraphsSvgView.graph_identity = graphContract.graph_identity;

export default InterpretacionFisicaGraphsSvgView;
